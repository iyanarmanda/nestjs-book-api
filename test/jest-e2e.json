{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"testRegex": ".e2e-spec.ts$",
	"transform": {
		"^.+\\.(t|j)s$": "@swc/jest"
	},
	"moduleNameMapper": {
		"^@/(.*)$": "<rootDir>/../src/$1",
		"^#/(.*)$": "<rootDir>/$1",
		"^\\$/(.*)$": "<rootDir>/../prisma/$1",
		"^(\\.{1,2}/.*)\\.js$": "$1"
	},
	"testEnvironment": "node",
	"transformIgnorePatterns": []
}
