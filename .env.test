# Needed for jest unit testing, integration/e2e testing, and CI/CD pipeline

NODE_ENV="test"

DATABASE_URL="postgresql://postgres:password@localhost:5433/integration-test"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="integration-test"

ADMIN_PASSWORD="passwordTest"
PASSWORD_PEPPER="pepperTest"
PASSWORD_SALT_ROUNDS=10

JWT_SECRET="secretJwtTest"

DOTENV_CONFIG_QUIET=true
